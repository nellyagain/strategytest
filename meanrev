// --- Universal Signal Outputs ---
plot(signal ? 1 : 0, title="SCR: Signal (Any)", display=display.none)
plot(signal ? close : 0, title="SCR: Entry Price", display=display.none)
plot(riskPct, title="SCR: Risk %", display=display.none)
plot(closePctVal, title="SCR: Close Strength %", display=display.none)
plot(volOk ? 1 : 0, title="SCR: Vol Valid", display=display.none)
plot(volZ, title="SCR: Vol Z-Score", display=display.none)

// --- Standard U&R Specific ---
plot(signalStd ? 1 : 0, title="SCR: U&R Signal", display=display.none)
plot(signalStd ? depthCalc : 0.0, title="SCR: Undercut Depth %", display=display.none)
plot(signalStd and not na(vwapAtSignal) and vwapAtSignal > 0 ? ((close - vwapAtSignal) / vwapAtSignal) * 100 : 0, title="SCR: % Above VWAP (Std)", display=display.none)
plot(signalStd ? structureLow : 0, title="SCR: Structure Floor", display=display.none)

// --- AVWAP Pullback Specific ---
plot(signalAvwap ? 1 : 0, title="SCR: AVWAP Pullback Signal", display=display.none)
plot(avwapPullbackValid ? pullbackVwap : 0, title="SCR: AVWAP Level", display=display.none)

// % Distance from AVWAP (key for scanning pullbacks)
pctFromAvwap = avwapPullbackValid and pullbackVwap > 0 ? ((close - pullbackVwap) / pullbackVwap) * 100 : 0.0
plot(pctFromAvwap, title="SCR: % from AVWAP", display=display.none)

// Setup Detection for Screener (scan for forming setups)
avwapSetupForming = isAvwapPullbackMode and avwapUndercutActive and not signalAvwap
plot(avwapSetupForming ? 1 : 0, title="SCR: AVWAP Setup Forming", display=display.none)

// Approaching AVWAP (within 2% above)
approachingAvwap = avwapPullbackValid and pctFromAvwap > 0 and pctFromAvwap <= 2.0
plot(approachingAvwap ? 1 : 0, title="SCR: Approaching AVWAP", display=display.none)

// At or Below AVWAP (potential entry zone)
atOrBelowAvwap = avwapPullbackValid and pctFromAvwap <= 0
plot(atOrBelowAvwap ? 1 : 0, title="SCR: At/Below AVWAP", display=display.none)

// AVWAP Breach Depth
plot(avwapBreachDepth, title="SCR: AVWAP Breach Depth %", display=display.none)

// Volume Contraction Status
plot(volContracted ? 1 : 0, title="SCR: Vol Contracted", display=display.none)

// Trend Status
plot(trendOk ? 1 : 0, title="SCR: Trend OK", display=display.none)


